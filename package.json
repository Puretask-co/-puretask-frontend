{
  "name": "puretask-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "start:ci": "next start -p 3001",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "node scripts/run-api-verification.js",
    "test:e2e": "node scripts/run-playwright-e2e.js",
    "test:e2e:smoke": "node scripts/run-playwright-e2e.js tests/e2e/smoke/auth-smoke.spec.ts --project=chromium",
    "test:e2e:headed": "node scripts/run-playwright-e2e.js --headed --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:fullstack:prepare": "node scripts/prepare-fullstack-test-env.js",
    "test:fullstack:seed-users": "node scripts/ensure-e2e-users.js",
    "test:fullstack:verify": "npm run test:fullstack:prepare && npm run test:api && npm run test:e2e:smoke",
    "audit:a11y": "node scripts/audit-accessibility.js",
    "audit:perf": "node scripts/audit-performance.js",
    "audit:all": "npm run audit:a11y && npm run audit:perf",
    "analyze:bundle": "node scripts/analyze-bundle.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.997.0",
    "@aws-sdk/s3-request-presigner": "^3.997.0",
    "@hookform/resolvers": "^5.2.2",
    "@lottiefiles/dotlottie-web": "^0.63.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "^10.39.0",
    "@tanstack/react-query": "^5.90.16",
    "@types/multer": "^2.0.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.1",
    "isomorphic-dompurify": "^2.35.0",
    "lucide-react": "^0.562.0",
    "mapbox-gl": "^3.18.1",
    "motion": "^12.34.3",
    "multer": "^2.0.2",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "three": "^0.183.1",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "msw": "^2.12.7",
    "@playwright/test": "^1.56.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
